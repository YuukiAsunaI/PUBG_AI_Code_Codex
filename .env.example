# PUBG Open API
PUBG_API_KEY=
PUBG_DEFAULT_SHARD=steam

# Discord
DISCORD_BOT_TOKEN=

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=pubg_ai
MYSQL_USER=pubg_ai
MYSQL_PASSWORD=

# Raw file storage
# Put this on the large HDD/SSD that will hold match and telemetry text files.
# Windows examples:
# PUBG_RAW_DATA_DIR=E:\PUBG_AI_Data\raw
# PUBG_RAW_DATA_DIR=D:\pubg_ai\raw
PUBG_RAW_DATA_DIR=./data/raw

# Keep raw files compressed by default because telemetry JSON can be very large.
PUBG_RAW_COMPRESSION=gzip

# If the external drive is missing, do not silently fall back to the project folder.
PUBG_ALLOW_STORAGE_FALLBACK=false

# 2D replay artifact storage
# Store generated replay timelines, snapshots, thumbnails, GIFs, videos, and render caches here.
# This can be the same large drive as PUBG_RAW_DATA_DIR, or a different fast SSD/HDD.
# Windows examples:
# PUBG_REPLAY_DATA_DIR=E:\PUBG_AI_Data\replays
# PUBG_REPLAY_DATA_DIR=F:\PUBG_AI_Replays
PUBG_REPLAY_DATA_DIR=./data/replays

# If the replay drive is missing, do not silently write replay artifacts into the project folder.
PUBG_ALLOW_REPLAY_STORAGE_FALLBACK=false

# Local management program settings
# The local app writes storage paths here when they are changed from the settings screen.
# Values in this JSON file override PUBG_RAW_DATA_DIR and PUBG_REPLAY_DATA_DIR at runtime.
PUBG_LOCAL_SETTINGS_FILE=./config/local_settings.json

# Collector defaults
# The local app can override these in config/local_settings.json.
PUBG_COLLECTOR_POLL_INTERVAL_SECONDS=180
PUBG_COLLECTOR_CYCLE_PLAYER_LIMIT=100
PUBG_PLAYER_LOOKUP_CHUNK_SIZE=10
